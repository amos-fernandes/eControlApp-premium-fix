{
  "expo": {
    "name": "eControle",
    "slug": "econtrole-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "econtrole",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2E1C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.econtrole.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Necessário para tirar fotos das ordens de serviço e escanear QR Code",
        "NSPhotoLibraryUsageDescription": "Necessário para selecionar fotos da galeria"
      }
    },
    "android": {
      "package": "com.econtrole.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D2E1C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para anexar nas ordens de serviço",
          "cameraPermission": "Permitir uso da câmera para fotografar ordens de serviço"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir uso da câmera para escanear QR Code e fotografar ordens de serviço"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
